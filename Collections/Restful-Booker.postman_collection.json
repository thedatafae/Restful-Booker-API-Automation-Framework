              "script": {
                "exec": [
                  "const res = pm.response.json();\r",
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));\r",
                  "pm.test(\"Token is generated\", () => pm.expect(res.token).to.be.a('string'));\r",
                  "pm.environment.set(\"token\", res.token);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
