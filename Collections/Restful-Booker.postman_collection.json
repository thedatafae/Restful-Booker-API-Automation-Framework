        {
          "name": "Update - Missing Content-Type",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test 1: Check that the server rejects the request\r",
                  "pm.test(\"Status code is 400 or 415\", () => {\r",
                  "    // We include 415 (Unsupported Media Type) because it's also a valid response for missing headers\r",
                  "    pm.expect([400, 415]).to.include(pm.response.code);\r",
                  "});\r",
                  "\r",
                  "// Test 2: Ensure the response is NOT the success message\r",
                  "pm.test(\"Should NOT return booking details\", () => {\r",
                  "    const responseText = pm.response.text();\r",
                  "    pm.expect(responseText).to.not.include(\"bookingid\");\r",
                  "});\r",
                  "\r",
                  "// Test 3: Check for a \"Bad Request\" string in the response body\r",
                  "pm.test(\"Response body confirms error\", () => {\r",
                  "    pm.expect(pm.response.text()).to.include(\"Bad Request\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "disabledSystemHeaders": {
              "content-type": true
            }
