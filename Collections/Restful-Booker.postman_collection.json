    {
      "name": "Regression_Suite (The Main Flow)",
      "item": [
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();\r",
                  "pm.environment.set(\"bookingId\", res.bookingid);\r",
                  "pm.test(\"Booking Successful\", () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{ \"firstname\": \"Faizan\", \"lastname\": \"Khan\", \"totalprice\": 111, \"depositpaid\": true, \"bookingdates\": { \"checkin\": \"2026-01-01\", \"checkout\": \"2026-01-10\" }, \"additionalneeds\": \"Breakfast\" }",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/booking",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "booking"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// We check status FIRST so the script doesn't crash on a 403\r",
                  "pm.test(\"Status code is 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "if (pm.response.code === 200) {\r",
                  "    const res = pm.response.json();\r",
                  "    pm.test(\"Verify Price Updated to 999\", () => {\r",
                  "        pm.expect(res.totalprice).to.eql(999);\r",
                  "    });\r",
                  "    pm.test(\"Verify Name Updated to James\", () => {\r",
                  "        pm.expect(res.firstname).to.eql(\"James\");\r",
                  "    });\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Cookie",
                "value": "token={{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"firstname\" : \"James\",\r\n    \"lastname\" : \"Brown\",\r\n    \"totalprice\" : 999,\r\n    \"depositpaid\" : true,\r\n    \"bookingdates\" : {\r\n        \"checkin\" : \"2026-01-01\",\r\n        \"checkout\" : \"2026-01-10\"\r\n    },\r\n    \"additionalneeds\" : \"Breakfast\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/booking/{{bookingId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "booking",
                "{{bookingId}}"
              ]
            }
          },
          "response": []
        },
